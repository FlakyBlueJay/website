---
interface Props {
  url: string;
  theme?: 'light' | 'dark';
}
---

<iframe
    width="100%"
    height="150"
    src={`https://odesli.co/embed/?url=${encodeURIComponent(Astro.props.url)}&theme=${Astro.props.theme || 'dark'}`}
    allowfullscreen
    sandbox="allow-same-origin allow-scripts allow-presentation allow-popups allow-popups-to-escape-sandbox"
    allow="clipboard-read; clipboard-write"></iframe>